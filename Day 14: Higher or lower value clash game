import random
import art

print(art.logo)

# --- INITIAL SETUP ---
score = 0
should_continue = True

# We pick the first "Person A" to start the game
person_a_name = random.choice(list(mixed_celebrities.keys()))

print("🌟 WELCOME TO THE HIGHER OR LOWER GAME 🌟")

while should_continue:
    # 1. Pick a "Person B" that is NOT the same as Person A
    person_b_name = random.choice(list(mixed_celebrities.keys()))
    while person_a_name == person_b_name:
        person_b_name = random.choice(list(mixed_celebrities.keys()))

    # Get the data for both
    data_a = mixed_celebrities[person_a_name]
    data_b = mixed_celebrities[person_b_name]

    # 2. Print all information for Choice A
    print(f"\n[CHOICE A]")
    print(f"Name:      {person_a_name}")
    print(f"Country:   {data_a['country']}")
    print(f"DOB:       {data_a['dob']}")
    print(f"Field:     {data_a['field']}")
    print(f"Parameter: {data_a['parameter']}")

    print(art.vs)

    # 3. Print all information for Choice B
    print(f"\n[CHOICE B]")
    print(f"Name:      {person_b_name}")
    print(f"Country:   {data_b['country']}")
    print(f"DOB:       {data_b['dob']}")
    print(f"Field:     {data_b['field']}")
    print(f"Parameter: {data_b['parameter']}")

    # 4. Logic: Determine the winner and store the name in greater_value
    if data_a['value'] > data_b['value']:
        greater_value_name = person_a_name
    else:
        greater_value_name = person_b_name

    # 5. Take User Input
    guess = input("\nWho has the higher value? Type 'A' or 'B': ").strip().upper()

    # 6. Check if user is correct
    # We find which name corresponds to the user's letter guess
    if guess == "A":
        user_choice_name = person_a_name
    else:
        user_choice_name = person_b_name

    if user_choice_name == greater_value_name:
        score += 1
        print(f"\n✅ CORRECT! Current Score: {score}")

        # IMPORTANT: The winner becomes the next Person A
        person_a_name = greater_value_name
    else:
        should_continue = False
        print(f"\n❌ WRONG. Game Over!")
        print(f"Final Score: {score}")
        print(f"Detailed Results:")
        print(f"- {person_a_name}: {data_a['value']:,}")
        print(f"- {person_b_name}: {data_b['value']:,}")
