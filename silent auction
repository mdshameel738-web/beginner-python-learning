def find_highest_bidder(bidders):
    winner =""
    highest_bidder=0
    for bidder in bidders:
        bid_price=bidders[bidder]
        if bid_price>highest_bidder:
            highest_bidder=bid_price
            winner =bidder
    print(f"the highest bidder is {winner} with a price of ${highest_bidder}")
